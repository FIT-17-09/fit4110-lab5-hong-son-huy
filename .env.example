# --- API Service ---
# API configuration
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_TOKEN=local-dev-token
SERVICE_NAME=access-gate
SERVICE_VERSION=0.5.0-team-gate
ENV=local

# Database configuration
POSTGRES_USER=lab05
POSTGRES_PASSWORD=lab05pass
POSTGRES_DB=accessgatedb

