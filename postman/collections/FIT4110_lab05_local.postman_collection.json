{
  "info": {
    "name": "FIT4110 Lab05 - Smart Campus Access Gate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('status field present', () => {",
              "  pm.expect(pm.response.json()).to.have.property('status');",
              "});",
              "pm.test('status is OK', () => {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "02 - Check Access (ALLOW)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('decisionId returned', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('decisionId');",
              "  pm.environment.set('decisionId', json.decisionId);",
              "});",
              "pm.test('allow is true', () => {",
              "  pm.expect(pm.response.json().allow).to.be.true;",
              "});",
              "pm.test('decisionType is ALLOW', () => {",
              "  pm.expect(pm.response.json().decisionType).to.eql('ALLOW');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cardId\": \"RFID-001\",\n  \"gateId\": \"GATE-01\",\n  \"timestamp\": \"2026-06-10T08:30:00+07:00\"\n}"
        },
        "url": "{{baseUrl}}/access/check"
      }
    },
    {
      "name": "03 - Check Access (DENY - blocked card)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('decisionType is DENY', () => {",
              "  pm.expect(pm.response.json().decisionType).to.eql('DENY');",
              "});",
              "pm.test('allow is false', () => {",
              "  pm.expect(pm.response.json().allow).to.be.false;",
              "});",
              "pm.test('reasonCode present', () => {",
              "  pm.expect(pm.response.json()).to.have.property('reasonCode');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cardId\": \"RFID-BLOCKED\",\n  \"gateId\": \"GATE-01\",\n  \"timestamp\": \"2026-06-10T08:35:00+07:00\"\n}"
        },
        "url": "{{baseUrl}}/access/check"
      }
    },
    {
      "name": "04 - Check Access (401 No Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('problem+json content-type', () => {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('problem+json');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
