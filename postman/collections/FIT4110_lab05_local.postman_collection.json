    {
      "name": "10 - Get Recent Access Logs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('response is array', () => {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "if (pm.response.json().length > 0) {",
              "  pm.test('log has required fields', () => {",
              "    const log = pm.response.json()[0];",
              "    pm.expect(log).to.have.property('logId');",
              "    pm.expect(log).to.have.property('cardId');",
              "    pm.expect(log).to.have.property('gateId');",
              "    pm.expect(log).to.have.property('status');",
              "    pm.environment.set('logId', log.logId);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": "{{baseUrl}}/access/logs/recent?limit=10"
      }
    },
    {
      "name": "11 - Get Access Log by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 404', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "if (pm.response.code === 200) {",
              "  pm.test('logId present', () => {",
              "    pm.expect(pm.response.json()).to.have.property('logId');",
              "  });",
              "  pm.test('direction is IN or OUT', () => {",
              "    pm.expect(['IN','OUT']).to.include(pm.response.json().direction);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": "{{baseUrl}}/access/logs/{{logId}}"
      }
    },
