    {
      "name": "06 - Get Decision by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 404', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "if (pm.response.code === 200) {",
              "  pm.test('decisionId present', () => {",
              "    pm.expect(pm.response.json()).to.have.property('decisionId');",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": "{{baseUrl}}/decisions/{{decisionId}}"
